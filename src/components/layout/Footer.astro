---
import { SITE } from "../../data/site-config";
import { footerNav } from "../../data/nav";
---

<footer class="bg-gray-50 dark:bg-gray-900 border-t border-gray-200 dark:border-gray-800 mt-16">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-12 lg:py-16">
    <!-- Top row: brand + columns -->
    <nav aria-label="Footer navigation">
    <div class="lg:grid lg:grid-cols-6 gap-8">
      <!-- Brand column -->
      <div class="lg:col-span-2 mb-10 lg:mb-0">
        <a href="/" class="inline-flex items-center gap-2.5">
          <svg class="h-7 w-7" viewBox="0 0 32 32" xmlns="http://www.w3.org/2000/svg">
            <rect width="32" height="32" rx="8" fill="#0D9488"/>
            <text x="16" y="23" text-anchor="middle" font-family="Inter,system-ui,sans-serif" font-weight="700" font-size="20" fill="white">G</text>
          </svg>
          <span class="font-bold text-gray-900 dark:text-white">Gulf Expat Hub</span>
        </a>
        <p class="mt-3 text-sm text-gray-500 dark:text-gray-400 max-w-xs leading-relaxed">
          Salary data, gratuity calculators, and relocation guides for expats in the UAE, Qatar, and Saudi Arabia.
        </p>
        <div class="mt-4 text-xs text-gray-400 dark:text-gray-500">
          Based on official {SITE.year} labor-law data from MoHRE, MHRSD, and MADLSA.
        </div>
        <div class="mt-3">
          <a href="mailto:contact@gulfexpathub.com" class="text-sm text-gray-500 dark:text-gray-400 hover:text-teal-600 dark:hover:text-teal-400 transition-colors">contact@gulfexpathub.com</a>
        </div>
      </div>

      <!-- Link columns -->
      <div>
        <h3 class="text-xs font-semibold text-gray-900 dark:text-white uppercase tracking-wider mb-4">Country Guides</h3>
        <ul class="space-y-2.5">
          {footerNav.countries.map((link) => (
            <li>
              <a href={link.href} class="text-sm text-gray-500 dark:text-gray-400 hover:text-teal-600 dark:hover:text-teal-400 transition-colors">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <div>
        <h3 class="text-xs font-semibold text-gray-900 dark:text-white uppercase tracking-wider mb-4">Calculators</h3>
        <ul class="space-y-2.5">
          {footerNav.calculators.map((link) => (
            <li>
              <a href={link.href} class="text-sm text-gray-500 dark:text-gray-400 hover:text-teal-600 dark:hover:text-teal-400 transition-colors">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <div>
        <h3 class="text-xs font-semibold text-gray-900 dark:text-white uppercase tracking-wider mb-4">Resources</h3>
        <ul class="space-y-2.5">
          {footerNav.resources.map((link) => (
            <li>
              <a href={link.href} class="text-sm text-gray-500 dark:text-gray-400 hover:text-teal-600 dark:hover:text-teal-400 transition-colors">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <div>
        <h3 class="text-xs font-semibold text-gray-900 dark:text-white uppercase tracking-wider mb-4">Company</h3>
        <ul class="space-y-2.5">
          {footerNav.legal.map((link) => (
            <li>
              <a href={link.href} class="text-sm text-gray-500 dark:text-gray-400 hover:text-teal-600 dark:hover:text-teal-400 transition-colors">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>
    </div>
    </nav>

    <!-- Bottom bar -->
    <div class="mt-12 pt-8 border-t border-gray-200 dark:border-gray-800">
      <div class="flex flex-col sm:flex-row justify-between items-center gap-4">
        <div class="text-xs text-gray-400 dark:text-gray-500">
          &copy; {SITE.year} {SITE.name}. All rights reserved.
        </div>
        <div class="flex items-center gap-4 text-xs text-gray-400 dark:text-gray-500">
          <span>Official {SITE.year} data</span>
          <span class="w-px h-3 bg-gray-300 dark:bg-gray-700"></span>
          <span>100% browser-calculated</span>
          <span class="w-px h-3 bg-gray-300 dark:bg-gray-700"></span>
          <span>Free to use</span>
        </div>
      </div>
    </div>
  </div>
</footer>
