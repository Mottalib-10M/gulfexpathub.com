---
interface Props {
  calculatorType: "salary" | "gratuity";
}

const { calculatorType } = Astro.props;
const embedUrl = `https://arabiaexpat.com/embed/${calculatorType}/`;
const embedCode = `<iframe src="${embedUrl}" width="100%" height="600" style="border:none;border-radius:12px;" loading="lazy" title="${calculatorType === 'salary' ? 'Salary' : 'Gratuity'} Calculator - Arabia Expat"></iframe>`;
---

<details class="mt-8 bg-gray-50 dark:bg-gray-800/50 rounded-2xl border border-gray-200 dark:border-gray-700 p-6">
  <summary class="cursor-pointer text-sm font-semibold text-gray-700 dark:text-gray-300 select-none">
    Embed this calculator on your website
  </summary>
  <div class="mt-4 space-y-3">
    <p class="text-sm text-gray-600 dark:text-gray-400">
      Copy and paste the code below to embed this {calculatorType} calculator on your own website or blog.
    </p>
    <div class="relative">
      <pre class="bg-gray-900 text-green-400 text-xs p-4 rounded-lg overflow-x-auto"><code>{embedCode}</code></pre>
    </div>
    <p class="text-xs text-gray-500 dark:text-gray-500">
      The widget is responsive and works on all screen sizes. Adjust the <code class="bg-gray-200 dark:bg-gray-700 px-1 rounded">height</code> attribute as needed.
    </p>
  </div>
</details>
