---
import GuideLayout from "../layouts/GuideLayout.astro";
import { buildBreadcrumbs } from "../lib/seo";

const breadcrumbs = [
  { name: "Home", url: "https://arabiaexpat.com/" },
  { name: "Terms of Use", url: "https://arabiaexpat.com/terms/" },
];
---

<GuideLayout
