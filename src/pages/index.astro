---
import Layout from "../layouts/Layout.astro";
import { SITE, COUNTRIES } from "../data/site-config";
import { buildOrganizationSchema, buildWebSiteSchema, buildFAQSchema } from "../lib/seo";
import FAQAccordion from "../components/ui/FAQAccordion.astro";

const faqs = [
  { question: "What do I need to know before moving to the Gulf in 2026?", answer: "Before relocating to the UAE, Qatar, or Saudi Arabia, research visa requirements (your employer typically sponsors your work visa), housing options and costs, healthcare and insurance (employer-provided), schooling for children if applicable, and the cultural environment. Each country has different processes for setting up utilities, getting a driving licence, and opening a bank account. Our country guides walk you through each step." },
  { question: "How do I set up utilities when I arrive in Dubai?", answer: "In Dubai, you register with DEWA (Dubai Electricity and Water Authority) for electricity and water. You need your tenancy contract, passport copy, and Emirates ID. In Abu Dhabi, the equivalent is ADDC. For internet and mobile, du and Etisalat (e&) are the two providers. Most setups can be done online or at service centers within a few days of arrival." },
  { question: "Which Gulf country is best for expat families?", answer: "The UAE, particularly Dubai, is widely considered the best Gulf country for families due to its extensive international school network (600+ schools), world-class healthcare, safe environment, and abundant recreational options. Qatar offers a compact, family-friendly lifestyle with lower costs. Saudi Arabia is rapidly improving with new entertainment venues and social reforms under Vision 2030." },
  { question: "Can I drive with my foreign licence in the Gulf?", answer: "Rules vary by country. The UAE allows licence conversion without a driving test for citizens of certain countries (UK, US, Canada, most EU). Others must take lessons and pass a test. Qatar requires a local licence, with conversion available for some nationalities. Saudi Arabia also allows conversion for selected countries. Our driving licence guide covers the full process for each country." },
  { question: "What are the best international schools in the Gulf?", answer: "Top international schools include GEMS, Taaleem, and Aldar Academies in the UAE; Qatar Academy and Doha College in Qatar; and the British and American international schools across Saudi Arabia. Curricula available include British, American, IB, Indian (CBSE/ICSE), and French. School fees range from AED 15,000 to AED 100,000+ per year depending on the school tier." },
  { question: "How much does it cost to live in the Gulf as an expat?", answer: "Costs vary significantly. Dubai is the most expensive: one-bedroom apartments cost AED 7,000-10,000/month. Riyadh is 20-30% cheaper. Doha falls in between. Groceries, dining, and transport follow similar patterns. For detailed breakdowns, see our cost-of-living guides for each country." },
];

const personSchema = {
  "@context": "https://schema.org",
  "@type": "Person",
  "name": "Mottalib Radif",
  "jobTitle": "Personal Finance Expert",
  "alumniOf": {
    "@type": "EducationalOrganization",
    "name": "INSEAD"
  },
  "url": "https://arabiaexpat.com/about/"
};

const schemas = [buildOrganizationSchema(), buildWebSiteSchema(), buildFAQSchema(faqs), personSchema];
---

<Layout
  title="Expat Guide 2026: Living in the UAE, Qatar and Saudi"
  description="Your complete 2026 guide to expat life in the Gulf. Visas, housing, schools, utilities, driving, and daily life tips for the UAE, Qatar, and Saudi Arabia."
  canonical="/"
  schemas={schemas}
>
  <!-- Hero -->
  <section class="relative overflow-hidden bg-gray-950 text-white">
    <div class="absolute inset-0 opacity-[0.03]" style="background-image: url(&quot;data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23ffffff' fill-opacity='1'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E&quot;);"></div>
    <div class="absolute top-0 right-0 w-1/2 h-full bg-gradient-to-l from-teal-900/20 to-transparent"></div>
    <div class="absolute bottom-0 left-0 w-96 h-96 bg-teal-600/10 rounded-full blur-3xl -translate-x-1/2 translate-y-1/2"></div>

    <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-20 lg:py-28">
      <div class="lg:grid lg:grid-cols-12 lg:gap-12 items-center">
        <div class="lg:col-span-7">
          <div class="inline-flex items-center gap-2 px-3 py-1.5 bg-teal-500/10 border border-teal-500/20 rounded-full text-teal-400 text-sm font-medium mb-6">
            <svg class="h-3.5 w-3.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
            Updated June 2026 with official data
          </div>

          <h1 class="text-4xl sm:text-5xl lg:text-[3.5rem] font-bold tracking-tight leading-[1.1]">
            Your complete guide to
            <span class="text-teal-400"> expat life</span> in the Gulf
          </h1>

          <p class="mt-5 text-lg text-gray-400 max-w-xl leading-relaxed">
            Everything you need to settle in the UAE, Qatar, or Saudi Arabia. Visa processes, housing, schools, driving licences, utilities, mobile plans, healthcare, and daily life -- all free, no sign-up needed.
          </p>

          <div class="mt-8 flex flex-col sm:flex-row gap-3">
            <a href="/uae/guide/" class="inline-flex items-center justify-center px-6 py-3.5 bg-teal-600 hover:bg-teal-500 text-white font-semibold rounded-xl transition-colors text-sm">
              Start with the UAE Guide
              <svg class="ml-2 h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
            </a>
            <a href="/guides/" class="inline-flex items-center justify-center px-6 py-3.5 bg-white/5 hover:bg-white/10 text-white font-semibold rounded-xl border border-white/10 transition-colors text-sm">
              Browse all guides
            </a>
          </div>

          <div class="mt-8 flex items-center gap-6 text-sm text-gray-500">
            <span class="flex items-center gap-1.5">
              <svg class="h-4 w-4 text-teal-500" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M5 9V7a5 5 0 0110 0v2a2 2 0 012 2v5a2 2 0 01-2 2H5a2 2 0 01-2-2v-5a2 2 0 012-2zm8-2v2H7V7a3 3 0 016 0z" clip-rule="evenodd"/></svg>
              Trusted by thousands of expats
            </span>
            <span class="flex items-center gap-1.5">
              <svg class="h-4 w-4 text-teal-500" fill="currentColor" viewBox="0 0 20 20"><path d="M10 2a8 8 0 100 16 8 8 0 000-16zm1 11H9v-2h2v2zm0-4H9V5h2v4z"/></svg>
              Government-sourced information
            </span>
          </div>
        </div>

        <!-- Right column: quick navigation cards -->
        <div class="hidden lg:block lg:col-span-5 mt-12 lg:mt-0">
          <div class="space-y-3">
            {[
              { label: "Driving Licence Guide", href: "/guides/driving-licence/", desc: "Get your Gulf driving licence: conversion, tests, costs" },
              { label: "Utilities Setup", href: "/guides/utilities-setup/", desc: "DEWA, ADDC, Kahramaa -- electricity, water, internet" },
              { label: "Schools & Education", href: "/guides/schools-education/", desc: "International schools, curricula, fees, and admissions" },
              { label: "Mobile & Internet", href: "/guides/telecom-mobile/", desc: "du, Etisalat, Ooredoo, STC -- plans, costs, eSIM" },
            ].map((item) => (
              <a href={item.href} class="block bg-white/[0.04] hover:bg-white/[0.07] border border-white/[0.06] rounded-2xl p-5 transition-colors group">
                <div class="flex items-center justify-between mb-2">
                  <span class="text-sm font-semibold text-white group-hover:text-teal-400 transition-colors">{item.label}</span>
                  <svg class="h-4 w-4 text-gray-500 group-hover:text-teal-400 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
                </div>
                <p class="text-xs text-gray-400">{item.desc}</p>
              </a>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Country Cards -->
  <section class="py-20 bg-white dark:bg-gray-950">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="max-w-2xl">
        <h2 class="text-2xl sm:text-3xl font-bold text-gray-900 dark:text-white">
          Three countries, one complete resource
        </h2>
        <p class="mt-3 text-gray-600 dark:text-gray-400">
          Each guide covers visas, housing, healthcare, education, daily life, and practical setup steps -- built from official 2026 government data.
        </p>
      </div>

      <div class="mt-10 grid grid-cols-1 md:grid-cols-3 gap-6">
        {Object.entries(COUNTRIES).map(([key, c]) => {
          const highlights = {
            uae: ["600+ international schools in Dubai", "Golden Visa for long-term residency", "DEWA and ADDC utility setup guides"],
            qatar: ["Zero VAT, compact city lifestyle", "World Cup legacy infrastructure", "Kahramaa utilities and QID process"],
            saudi: ["Vision 2030 social transformation", "Riyadh Metro now operational", "Premium Residency options available"],
          };
          const expats = { uae: "8.9M", qatar: "2.4M", saudi: "10.4M" };
          return (
            <div class="group relative bg-gray-50 dark:bg-gray-900 rounded-2xl border border-gray-200 dark:border-gray-800 p-7 hover:border-teal-400 dark:hover:border-teal-600 transition-all hover:shadow-lg">
              <div class="flex items-center gap-3 mb-4">
                <span class="text-3xl">{c.flag === "AE" ? "\u{1F1E6}\u{1F1EA}" : c.flag === "QA" ? "\u{1F1F6}\u{1F1E6}" : "\u{1F1F8}\u{1F1E6}"}</span>
                <div>
                  <h3 class="text-lg font-bold text-gray-900 dark:text-white">{c.fullName}</h3>
                  <span class="text-xs text-gray-500">{expats[key as keyof typeof expats]} expats</span>
                </div>
              </div>

              <ul class="space-y-2 mb-6">
                {highlights[key as keyof typeof highlights]?.map((h: string) => (
                  <li class="flex items-start gap-2 text-sm text-gray-600 dark:text-gray-400">
                    <svg class="h-4 w-4 text-teal-500 mt-0.5 shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
                    {h}
                  </li>
                ))}
              </ul>

              <a href={`/${c.slug}/guide/`} class="inline-flex items-center gap-1.5 text-sm font-semibold text-teal-600 dark:text-teal-400 hover:text-teal-700 dark:hover:text-teal-300 transition-colors">
                Read the {c.name} guide
                <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
              </a>
            </div>
          );
        })}
      </div>
    </div>
  </section>

  <!-- Why the Gulf Section -->
  <section class="py-16 bg-gray-50 dark:bg-gray-900">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl sm:text-3xl font-bold text-gray-900 dark:text-white mb-8">
        Why professionals choose the Gulf in 2026
      </h2>
      <div class="prose dark:prose-invert max-w-none">
        <p>The Gulf Cooperation Council countries attract over 30 million expatriate workers, and the numbers continue to grow. The UAE alone hosts 8.9 million foreign residents, representing 88% of its total population. Saudi Arabia's Vision 2030 program has created thousands of new roles across technology, entertainment, tourism, and infrastructure. Qatar's post-World Cup economy is expanding into finance, education, and LNG production at record levels.</p>
        <p>Beyond financial advantages, Gulf countries offer a unique living environment. Dubai ranks among the world's safest cities. Saudi Arabia has opened cinemas, concert venues, and mixed-gender social spaces. Qatar's World Cup infrastructure left behind world-class stadiums, a metro system, and upgraded road networks. International schools serve every major curriculum, and healthcare facilities meet or exceed Western standards.</p>
        <p>Setting up your life as a new arrival involves practical steps that differ from country to country: obtaining your residence visa, finding housing, setting up electricity and water, getting a local SIM card, opening a bank account, converting your driving licence, and enrolling children in school. Our guides walk you through each of these steps with up-to-date 2026 information and costs.</p>
      </div>
    </div>
  </section>

  <!-- Expat Life Guides Section -->
  <section class="py-20 bg-white dark:bg-gray-950">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="flex items-end justify-between mb-10">
        <div>
          <h2 class="text-2xl sm:text-3xl font-bold text-gray-900 dark:text-white">
            Practical guides for Gulf expats
          </h2>
          <p class="mt-2 text-gray-600 dark:text-gray-400">
            Step-by-step guides for every part of settling in the Gulf.
          </p>
        </div>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
        {[
          { title: "Driving Licence Guide 2026", href: "/guides/driving-licence/", tag: "Setup", desc: "Licence conversion, driving schools, costs, and requirements across UAE, Qatar, Saudi." },
          { title: "Utilities Setup Guide", href: "/guides/utilities-setup/", tag: "Setup", desc: "DEWA, ADDC, Kahramaa, SEC. How to connect electricity, water, and internet." },
          { title: "Schools & Education 2026", href: "/guides/schools-education/", tag: "Family", desc: "International school systems, curricula, fees, KHDA ratings, and university options." },
          { title: "Mobile & Internet Guide", href: "/guides/telecom-mobile/", tag: "Setup", desc: "du, Etisalat, Ooredoo, STC. Plans, costs, eSIM, and home broadband options." },
          { title: "Healthcare for Expats", href: "/guides/healthcare-expats-gulf/", tag: "Health", desc: "Insurance, hospitals, pharmacies, and emergency care across the Gulf." },
          { title: "Banking for Expats", href: "/guides/banking-expats-gulf/", tag: "Finance", desc: "Opening accounts, remittances, credit cards, and digital banking." },
          { title: "UAE Cost of Living", href: "/uae/cost-of-living/", tag: "Cost", desc: "Rent, groceries, transport, and school fees in Dubai and Abu Dhabi." },
          { title: "Best Country for Expats", href: "/guides/best-country-for-expats-gulf/", tag: "Guide", desc: "UAE vs Qatar vs Saudi Arabia: lifestyle, cost, and opportunity compared." },
        ].map((guide) => (
          <a href={guide.href} class="group bg-white dark:bg-gray-800 rounded-xl border border-gray-200 dark:border-gray-700 p-5 hover:border-teal-400 dark:hover:border-teal-600 hover:shadow-md transition-all">
            <span class="inline-block text-[10px] font-semibold uppercase tracking-wider text-teal-600 dark:text-teal-400 bg-teal-50 dark:bg-teal-900/30 px-2 py-0.5 rounded-md mb-3">{guide.tag}</span>
            <h3 class="font-semibold text-gray-900 dark:text-white text-sm group-hover:text-teal-600 dark:group-hover:text-teal-400 transition-colors">{guide.title}</h3>
            <p class="mt-1.5 text-xs text-gray-500 dark:text-gray-400 leading-relaxed">{guide.desc}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Sister Sites Cross-links -->
  <section class="py-16 bg-gray-50 dark:bg-gray-900">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl sm:text-3xl font-bold text-gray-900 dark:text-white mb-8">
        More Gulf resources from our network
      </h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <a href="https://taxfreesalaries.com/" target="_blank" rel="noopener" class="bg-white dark:bg-gray-800 rounded-2xl border border-gray-200 dark:border-gray-700 p-6 hover:border-teal-400 dark:hover:border-teal-600 hover:shadow-md transition-all group">
          <h3 class="font-bold text-gray-900 dark:text-white group-hover:text-teal-600 dark:group-hover:text-teal-400 transition-colors">Salary & Employment Data</h3>
          <p class="mt-2 text-sm text-gray-500 dark:text-gray-400">Compare tax-free salaries across 20+ professions. Gratuity calculators, labor law guides, and salary negotiation tips.</p>
          <span class="mt-3 inline-block text-xs text-teal-600 dark:text-teal-400 font-medium">taxfreesalaries.com</span>
        </a>
        <a href="https://thedubaisetup.com/" target="_blank" rel="noopener" class="bg-white dark:bg-gray-800 rounded-2xl border border-gray-200 dark:border-gray-700 p-6 hover:border-teal-400 dark:hover:border-teal-600 hover:shadow-md transition-all group">
          <h3 class="font-bold text-gray-900 dark:text-white group-hover:text-teal-600 dark:group-hover:text-teal-400 transition-colors">Business Setup</h3>
          <p class="mt-2 text-sm text-gray-500 dark:text-gray-400">Free zone vs mainland, trade licences, PRO services, and company formation guides for the Gulf.</p>
          <span class="mt-3 inline-block text-xs text-teal-600 dark:text-teal-400 font-medium">thedubaisetup.com</span>
        </a>
        <a href="https://uaepriceindex.com/" target="_blank" rel="noopener" class="bg-white dark:bg-gray-800 rounded-2xl border border-gray-200 dark:border-gray-700 p-6 hover:border-teal-400 dark:hover:border-teal-600 hover:shadow-md transition-all group">
          <h3 class="font-bold text-gray-900 dark:text-white group-hover:text-teal-600 dark:group-hover:text-teal-400 transition-colors">Property Prices</h3>
          <p class="mt-2 text-sm text-gray-500 dark:text-gray-400">Rental and purchase prices across Dubai, Abu Dhabi, Doha, Riyadh, and Jeddah. Area-by-area data.</p>
          <span class="mt-3 inline-block text-xs text-teal-600 dark:text-teal-400 font-medium">uaepriceindex.com</span>
        </a>
      </div>
    </div>
  </section>

  <!-- FAQ Section -->
  <section class="py-16 bg-white dark:bg-gray-950">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <FAQAccordion faqs={faqs} />
    </div>
  </section>

  <!-- Trust / methodology section -->
  <section class="py-16 bg-gray-50 dark:bg-gray-900 border-t border-gray-200 dark:border-gray-800">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="lg:grid lg:grid-cols-12 lg:gap-12 items-start">
        <div class="lg:col-span-4">
          <div class="flex items-center gap-4">
            <img
              src={SITE.author.image}
              alt={SITE.author.name}
              class="h-14 w-14 rounded-full bg-gray-200 dark:bg-gray-700 object-cover"
              width="56"
              height="56"
            />
            <div>
              <div class="font-bold text-gray-900 dark:text-white">{SITE.author.name}</div>
              <div class="text-sm text-gray-500 dark:text-gray-400">{SITE.author.credentials} &middot; {SITE.author.role}</div>
            </div>
          </div>
          <p class="mt-4 text-sm text-gray-600 dark:text-gray-400 leading-relaxed">
            {SITE.author.bio}
          </p>
          <a href="/about/" class="mt-3 inline-block text-sm font-medium text-teal-600 dark:text-teal-400 hover:underline">
            About our methodology
          </a>
        </div>

        <div class="lg:col-span-8 mt-10 lg:mt-0">
          <div class="grid grid-cols-1 sm:grid-cols-3 gap-6">
            <div class="text-center sm:text-left">
              <div class="text-3xl font-bold text-gray-900 dark:text-white tabular-nums">3</div>
              <div class="text-sm text-gray-600 dark:text-gray-400 mt-1">Gulf countries covered</div>
              <div class="text-xs text-gray-400 dark:text-gray-500 mt-0.5">UAE, Qatar, and Saudi Arabia</div>
            </div>
            <div class="text-center sm:text-left">
              <div class="text-3xl font-bold text-gray-900 dark:text-white">15+</div>
              <div class="text-sm text-gray-600 dark:text-gray-400 mt-1">Practical setup guides</div>
              <div class="text-xs text-gray-400 dark:text-gray-500 mt-0.5">Visas, housing, schools, utilities, and more</div>
            </div>
            <div class="text-center sm:text-left">
              <div class="text-3xl font-bold text-gray-900 dark:text-white">2026</div>
              <div class="text-sm text-gray-600 dark:text-gray-400 mt-1">Updated with latest data</div>
              <div class="text-xs text-gray-400 dark:text-gray-500 mt-0.5">Government sources verified quarterly</div>
            </div>
          </div>

          <div class="mt-8 p-4 bg-white dark:bg-gray-800 rounded-xl border border-gray-200 dark:border-gray-700">
            <div class="flex items-start gap-3">
              <svg class="h-5 w-5 text-teal-500 mt-0.5 shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M2.166 4.999A11.954 11.954 0 0010 1.944 11.954 11.954 0 0017.834 5c.11.65.166 1.32.166 2.001 0 5.225-3.34 9.67-8 11.317C5.34 16.67 2 12.225 2 7c0-.682.057-1.35.166-2.001zm11.541 3.708a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
              <div>
                <div class="text-sm font-semibold text-gray-900 dark:text-white">Based on official 2026 government data</div>
                <div class="text-xs text-gray-500 dark:text-gray-400 mt-0.5">
                  Visa requirements, utility processes, school ratings, and regulatory information are sourced directly from UAE, Saudi, and Qatar government publications. Last reviewed June 2026.
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>
