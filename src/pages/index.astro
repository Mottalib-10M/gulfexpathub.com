---
import Layout from "../layouts/Layout.astro";
import { SITE, COUNTRIES } from "../data/site-config";
import { buildOrganizationSchema, buildWebSiteSchema, buildFAQSchema } from "../lib/seo";
import FAQAccordion from "../components/ui/FAQAccordion.astro";

const countryStats = {
  uae: { avgSalary: "AED 15,200/mo", topRole: "Software Engineer", topSalary: "AED 28,000/mo", expats: "8.9M" },
  qatar: { avgSalary: "QAR 12,800/mo", topRole: "Project Manager", topSalary: "QAR 25,500/mo", expats: "2.4M" },
  saudi: { avgSalary: "SAR 11,500/mo", topRole: "Petroleum Engineer", topSalary: "SAR 32,000/mo", expats: "10.4M" },
};

const faqs = [
  { question: "Which Gulf country pays the highest salaries for expats in 2026?", answer: "The UAE, particularly Dubai and Abu Dhabi, pays the highest average salaries across most professions. Software engineers earn AED 8,000-40,000/month, doctors AED 20,000-70,000/month. However, Saudi Arabia offers premium packages for giga-project roles, and Qatar's energy sector matches or exceeds UAE rates for senior positions. All three countries offer zero personal income tax." },
  { question: "Are Gulf salaries really tax-free in 2026?", answer: "Yes. The UAE, Qatar, and Saudi Arabia impose zero personal income tax on employment income. Your gross salary is your net take-home pay. Saudi nationals pay 9.75% GOSI social insurance, and UAE/GCC nationals pay GPSSA contributions, but expatriates are fully exempt from all salary deductions in every Gulf country." },
  { question: "How much can I save working in the Gulf?", answer: "Most Gulf expats save 25-40% of their monthly salary after expenses. A mid-level professional earning AED 20,000/month in Dubai can save AED 5,000-8,000 monthly. In Riyadh, where living costs are 20-30% lower, savings rates are even higher. Employer-provided housing and flight allowances further boost savings compared to taxed Western countries." },
  { question: "What end-of-service benefits do Gulf expats receive?", answer: "All three Gulf countries mandate end-of-service gratuity payments. The UAE pays 21 days basic salary per year for the first 5 years, then 30 days after. Saudi Arabia pays half a month for the first 5 years, then a full month. Qatar pays a minimum of 3 weeks per year. Use our free calculators to estimate your exact entitlement." },
  { question: "Do I need a job offer before moving to the Gulf?", answer: "For standard employment visas, yes. Your employer sponsors your work visa in all three countries. However, the UAE offers self-sponsored options including the Golden Visa (10-year, for investors and skilled professionals) and Green Visa (5-year, for high earners). Saudi Arabia has Premium Residency, and Qatar offers permanent residency for long-term residents." },
  { question: "What is the cost of living in Dubai compared to Riyadh and Doha?", answer: "Dubai is the most expensive: a one-bedroom apartment costs AED 7,000-10,000/month. Riyadh is 20-30% cheaper at SAR 2,500-5,000/month. Doha falls in between at QAR 4,500-7,500/month. Groceries, dining, and transport follow similar patterns. Dubai has 5% VAT, Saudi has 15% VAT, and Qatar has no VAT." },
];

const personSchema = {
  "@context": "https://schema.org",
  "@type": "Person",
  "name": "Mottalib Radif",
  "jobTitle": "Personal Finance Expert",
  "alumniOf": {
    "@type": "EducationalOrganization",
    "name": "INSEAD"
  },
  "url": "https://gulfexpathub.com/about/"
};

const schemas = [buildOrganizationSchema(), buildWebSiteSchema(), buildFAQSchema(faqs), personSchema];
---

<Layout
  title="Gulf Expat Salaries, Gratuity Calculators and Guides 2026"
  description="Compare tax-free salaries, calculate end-of-service gratuity, and plan your move to the UAE, Qatar, or Saudi Arabia. Free 2026 data for 20+ professions."
  canonical="/"
  schemas={schemas}
>
  <!-- Hero -->
  <section class="relative overflow-hidden bg-gray-950 text-white">
    <div class="absolute inset-0 opacity-[0.03]" style="background-image: url(&quot;data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23ffffff' fill-opacity='1'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E&quot;);"></div>
    <div class="absolute top-0 right-0 w-1/2 h-full bg-gradient-to-l from-teal-900/20 to-transparent"></div>
    <div class="absolute bottom-0 left-0 w-96 h-96 bg-teal-600/10 rounded-full blur-3xl -translate-x-1/2 translate-y-1/2"></div>

    <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-20 lg:py-28">
      <div class="lg:grid lg:grid-cols-12 lg:gap-12 items-center">
        <div class="lg:col-span-7">
          <div class="inline-flex items-center gap-2 px-3 py-1.5 bg-teal-500/10 border border-teal-500/20 rounded-full text-teal-400 text-sm font-medium mb-6">
            <svg class="h-3.5 w-3.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
            Updated June 2026 with official labor-law data
          </div>

          <h1 class="text-4xl sm:text-5xl lg:text-[3.5rem] font-bold tracking-tight leading-[1.1]">
            Compare salaries across
            <span class="text-teal-400"> 20 professions</span> in the Gulf
          </h1>

          <p class="mt-5 text-lg text-gray-400 max-w-xl leading-relaxed">
            Side-by-side salary data for the UAE, Qatar, and Saudi Arabia. Plus gratuity calculators, visa timelines, and cost-of-living breakdowns -- all free, no sign-up needed.
          </p>

          <div class="mt-8 flex flex-col sm:flex-row gap-3">
            <a href="/uae/salaries/" class="inline-flex items-center justify-center px-6 py-3.5 bg-teal-600 hover:bg-teal-500 text-white font-semibold rounded-xl transition-colors text-sm">
              Browse 2026 salary data
              <svg class="ml-2 h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
            </a>
            <a href="/uae/gratuity-calculator/" class="inline-flex items-center justify-center px-6 py-3.5 bg-white/5 hover:bg-white/10 text-white font-semibold rounded-xl border border-white/10 transition-colors text-sm">
              Calculate your gratuity
            </a>
          </div>

          <div class="mt-8 flex items-center gap-6 text-sm text-gray-500">
            <span class="flex items-center gap-1.5">
              <svg class="h-4 w-4 text-teal-500" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M5 9V7a5 5 0 0110 0v2a2 2 0 012 2v5a2 2 0 01-2 2H5a2 2 0 01-2-2v-5a2 2 0 012-2zm8-2v2H7V7a3 3 0 016 0z" clip-rule="evenodd"/></svg>
              Runs in your browser
            </span>
            <span class="flex items-center gap-1.5">
              <svg class="h-4 w-4 text-teal-500" fill="currentColor" viewBox="0 0 20 20"><path d="M10 2a8 8 0 100 16 8 8 0 000-16zm1 11H9v-2h2v2zm0-4H9V5h2v4z"/></svg>
              MoHRE / MHRSD / MADLSA verified
            </span>
          </div>
        </div>

        <!-- Right column: quick stat cards -->
        <div class="hidden lg:block lg:col-span-5 mt-12 lg:mt-0">
          <div class="space-y-3">
            {Object.entries(countryStats).map(([key, stats]) => {
              const country = COUNTRIES[key as keyof typeof COUNTRIES];
              return (
                <a href={`/${country.slug}/salaries/`} class="block bg-white/[0.04] hover:bg-white/[0.07] border border-white/[0.06] rounded-2xl p-5 transition-colors group">
                  <div class="flex items-center justify-between mb-3">
                    <span class="text-sm font-semibold text-white">{country.name}</span>
                    <span class="text-xs text-gray-500">{stats.expats} expats</span>
                  </div>
                  <div class="flex items-end justify-between">
                    <div>
                      <div class="text-xs text-gray-500 mb-1">Avg. expat salary</div>
                      <div class="text-xl font-bold text-teal-400 tabular-nums">{stats.avgSalary}</div>
                    </div>
                    <div class="text-right">
                      <div class="text-xs text-gray-500 mb-1">Top: {stats.topRole}</div>
                      <div class="text-sm font-semibold text-white tabular-nums">{stats.topSalary}</div>
                    </div>
                  </div>
                  <div class="mt-3 flex gap-1 items-end h-6">
                    <div class="flex-1 bg-teal-500/20 rounded-sm" style={`height: ${key === 'uae' ? '100' : key === 'qatar' ? '75' : '65'}%`}></div>
                    <div class="flex-1 bg-teal-500/30 rounded-sm" style={`height: ${key === 'uae' ? '85' : key === 'qatar' ? '90' : '80'}%`}></div>
                    <div class="flex-1 bg-teal-500/20 rounded-sm" style={`height: ${key === 'uae' ? '70' : key === 'qatar' ? '60' : '100'}%`}></div>
                    <div class="flex-1 bg-teal-500/40 rounded-sm" style={`height: ${key === 'uae' ? '95' : key === 'qatar' ? '70' : '55'}%`}></div>
                    <div class="flex-1 bg-teal-500/25 rounded-sm" style={`height: ${key === 'uae' ? '60' : key === 'qatar' ? '85' : '75'}%`}></div>
                    <div class="flex-1 bg-teal-500/35 rounded-sm" style={`height: ${key === 'uae' ? '80' : key === 'qatar' ? '55' : '90'}%`}></div>
                  </div>
                </a>
              );
            })}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Country Cards -->
  <section class="py-20 bg-white dark:bg-gray-950">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="max-w-2xl">
        <h2 class="text-2xl sm:text-3xl font-bold text-gray-900 dark:text-white">
          Three countries, one comparison
        </h2>
        <p class="mt-3 text-gray-600 dark:text-gray-400">
          Each guide covers salaries, end-of-service benefits, visa routes, and monthly living costs -- built from official 2026 government data.
        </p>
      </div>

      <div class="mt-10 grid grid-cols-1 md:grid-cols-3 gap-6">
        {Object.entries(COUNTRIES).map(([key, c]) => {
          const stats = countryStats[key as keyof typeof countryStats];
          const highlights = {
            uae: ["0% income tax for all residents", "Golden Visa for high earners", "MoHRE-regulated contracts"],
            qatar: ["Tax-free salary packages", "QAR 1,000 minimum wage since 2021", "FIFA-era infrastructure boom"],
            saudi: ["Vision 2030 driving new sectors", "GOSI social-insurance system", "Fastest-growing expat job market"],
          };
          return (
            <div class="group relative bg-gray-50 dark:bg-gray-900 rounded-2xl border border-gray-200 dark:border-gray-800 p-7 hover:border-teal-400 dark:hover:border-teal-600 transition-all hover:shadow-lg">
              <div class="flex items-center gap-3 mb-4">
                <span class="text-3xl">{c.flag === "AE" ? "\u{1F1E6}\u{1F1EA}" : c.flag === "QA" ? "\u{1F1F6}\u{1F1E6}" : "\u{1F1F8}\u{1F1E6}"}</span>
                <div>
                  <h3 class="text-lg font-bold text-gray-900 dark:text-white">{c.fullName}</h3>
                  <span class="text-xs text-gray-500">{c.currency} &middot; {stats.expats} expats</span>
                </div>
              </div>

              <div class="bg-teal-50 dark:bg-teal-900/20 rounded-xl p-3 mb-4">
                <div class="text-xs text-teal-700 dark:text-teal-400 font-medium mb-0.5">Average expat salary</div>
                <div class="text-lg font-bold text-teal-700 dark:text-teal-300 tabular-nums">{stats.avgSalary}</div>
              </div>

              <ul class="space-y-2 mb-6">
                {highlights[key]?.map((h: string) => (
                  <li class="flex items-start gap-2 text-sm text-gray-600 dark:text-gray-400">
                    <svg class="h-4 w-4 text-teal-500 mt-0.5 shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
                    {h}
                  </li>
                ))}
              </ul>

              <a href={`/${c.slug}/salaries/`} class="inline-flex items-center gap-1.5 text-sm font-semibold text-teal-600 dark:text-teal-400 hover:text-teal-700 dark:hover:text-teal-300 transition-colors">
                Explore {c.name} salaries
                <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
              </a>
            </div>
          );
        })}
      </div>
    </div>
  </section>

  <!-- Why the Gulf Section (editorial/SEO content) -->
  <section class="py-16 bg-gray-50 dark:bg-gray-900">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl sm:text-3xl font-bold text-gray-900 dark:text-white mb-8">
        Why professionals choose the Gulf in 2026
      </h2>
      <div class="prose dark:prose-invert max-w-none">
        <p>The Gulf Cooperation Council countries attract over 30 million expatriate workers, and the numbers continue to grow. The UAE alone hosts 8.9 million foreign residents, representing 88% of its total population. Saudi Arabia's Vision 2030 program has created thousands of new roles across technology, entertainment, tourism, and infrastructure. Qatar's post-World Cup economy is expanding into finance, education, and LNG production at record levels.</p>
        <p>The financial case for Gulf employment is straightforward. All three countries impose zero personal income tax on salaries. A software engineer earning AED 25,000 per month in Dubai takes home AED 25,000. The same role paying GBP 5,500 in London leaves roughly GBP 3,900 after tax and National Insurance. Over a typical 3-year Gulf contract, the tax savings alone can exceed $80,000. Add employer-provided housing, annual flights, and health insurance, and the total compensation gap widens further.</p>
        <p>Beyond the financial advantage, Gulf countries offer a unique professional environment. Riyadh's giga-projects (NEOM, The Line, Qiddiya) involve engineering and design challenges that do not exist anywhere else on earth. Dubai's position as a global business hub means exposure to markets spanning Africa, South Asia, and the Middle East. Qatar's concentrated wealth and small population create opportunities for rapid career advancement that might take a decade in more established markets.</p>
        <p>Living conditions have improved dramatically across the region. Dubai ranks among the world's safest cities. Saudi Arabia has opened cinemas, concert venues, and mixed-gender social spaces. Qatar's World Cup infrastructure left behind world-class stadiums, a metro system, and upgraded road networks. International schools serve every major curriculum, and healthcare facilities meet or exceed Western standards.</p>
      </div>
    </div>
  </section>

  <!-- Calculator Preview Section -->
  <section class="py-20 bg-white dark:bg-gray-950">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="lg:grid lg:grid-cols-2 lg:gap-16 items-center">
        <div>
          <h2 class="text-2xl sm:text-3xl font-bold text-gray-900 dark:text-white">
            Gratuity calculators built on actual labor law
          </h2>
          <p class="mt-4 text-gray-600 dark:text-gray-400 leading-relaxed">
            End-of-service benefits vary by country, contract type, and years worked.
            These calculators apply the exact formulas from MoHRE (UAE), MHRSD (Saudi Arabia), and MADLSA (Qatar) regulations.
          </p>

          <div class="mt-6 bg-gray-50 dark:bg-gray-900 rounded-2xl border border-gray-200 dark:border-gray-700 p-5">
            <div class="text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider mb-3">Example result &middot; UAE unlimited contract</div>
            <div class="grid grid-cols-3 gap-4 text-sm">
              <div>
                <div class="text-gray-500 dark:text-gray-400 text-xs">Service</div>
                <div class="font-semibold text-gray-900 dark:text-white">5 years</div>
              </div>
              <div>
                <div class="text-gray-500 dark:text-gray-400 text-xs">Basic salary</div>
                <div class="font-semibold text-gray-900 dark:text-white">AED 10,000</div>
              </div>
              <div>
                <div class="text-gray-500 dark:text-gray-400 text-xs">Gratuity owed</div>
                <div class="font-bold text-teal-600 dark:text-teal-400 text-lg">AED 24,500</div>
              </div>
            </div>
            <div class="mt-3 text-xs text-gray-400 dark:text-gray-500">
              21 days/year for first 5 years = 105 days x (10,000/30) = AED 35,000 full entitlement, reduced for unlimited contract early resignation
            </div>
          </div>

          <div class="mt-6 flex flex-wrap gap-3">
            <a href="/uae/gratuity-calculator/" class="inline-flex items-center px-5 py-2.5 bg-teal-600 hover:bg-teal-500 text-white text-sm font-semibold rounded-xl transition-colors">UAE Gratuity Calculator</a>
            <a href="/saudi-arabia/gratuity-calculator/" class="inline-flex items-center px-5 py-2.5 bg-white dark:bg-gray-800 hover:bg-gray-100 dark:hover:bg-gray-700 text-gray-900 dark:text-white text-sm font-semibold rounded-xl border border-gray-200 dark:border-gray-700 transition-colors">Saudi EOSB Calculator</a>
            <a href="/qatar/gratuity-calculator/" class="inline-flex items-center px-5 py-2.5 bg-white dark:bg-gray-800 hover:bg-gray-100 dark:hover:bg-gray-700 text-gray-900 dark:text-white text-sm font-semibold rounded-xl border border-gray-200 dark:border-gray-700 transition-colors">Qatar Gratuity Calculator</a>
          </div>
        </div>

        <div class="mt-12 lg:mt-0">
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            {[
              { title: "UAE Gratuity", href: "/uae/gratuity-calculator/", desc: "MoHRE formula for limited and unlimited contracts", icon: "calc" },
              { title: "Saudi EOSB", href: "/saudi-arabia/gratuity-calculator/", desc: "Half-month and full-month tiers per MHRSD", icon: "calc" },
              { title: "Qatar Gratuity", href: "/qatar/gratuity-calculator/", desc: "MADLSA minimum end-of-service entitlements", icon: "calc" },
              { title: "UAE Salary Breakdown", href: "/uae/salary-calculator/", desc: "Base, housing, transport. Zero income tax", icon: "salary" },
              { title: "Saudi Take-Home Pay", href: "/saudi-arabia/salary-calculator/", desc: "GOSI deductions for nationals and expats", icon: "salary" },
              { title: "Qatar Salary Breakdown", href: "/qatar/salary-calculator/", desc: "Zero-tax, zero-contribution package split", icon: "salary" },
            ].map((calc) => (
              <a href={calc.href} class="bg-gray-50 dark:bg-gray-900 rounded-xl border border-gray-200 dark:border-gray-800 p-4 hover:border-teal-400 dark:hover:border-teal-500 hover:shadow-md transition-all group">
                <div class="flex items-center gap-2 mb-2">
                  {calc.icon === "calc" ? (
                    <svg class="h-4 w-4 text-teal-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 14h.01M12 14h.01M15 11h.01M12 11h.01M9 11h.01M7 21h10a2 2 0 002-2V5a2 2 0 00-2-2H7a2 2 0 00-2 2v14a2 2 0 002 2z"/></svg>
                  ) : (
                    <svg class="h-4 w-4 text-gold-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                  )}
                  <h3 class="font-semibold text-sm text-gray-900 dark:text-white group-hover:text-teal-600 dark:group-hover:text-teal-400 transition-colors">{calc.title}</h3>
                </div>
                <p class="text-xs text-gray-500 dark:text-gray-400 leading-relaxed">{calc.desc}</p>
              </a>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Guides section -->
  <section class="py-20 bg-gray-50 dark:bg-gray-900">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="flex items-end justify-between mb-10">
        <div>
          <h2 class="text-2xl sm:text-3xl font-bold text-gray-900 dark:text-white">
            Guides and references
          </h2>
          <p class="mt-2 text-gray-600 dark:text-gray-400">
            Visa rules, labor law summaries, and cost-of-living data for each country.
          </p>
        </div>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
        {[
          { title: "UAE Visa Guide 2026", href: "/uae/visa-guide/", tag: "Visa", desc: "Employment, Golden, Green, and Freelancer visa types with processing times." },
          { title: "Saudi Labor Law 2026", href: "/saudi-arabia/labor-law/", tag: "Law", desc: "Working hours, leave entitlements, termination rules, and Saudization quotas." },
          { title: "Relocating from India", href: "/relocating-from/india/", tag: "Relocation", desc: "Document checklist, tax implications, and salary expectations for Indian professionals." },
          { title: "UAE Cost of Living", href: "/uae/cost-of-living/", tag: "Cost", desc: "Rent, groceries, transport, and school fees in Dubai and Abu Dhabi." },
          { title: "Qatar Expat Guide", href: "/qatar/guide/", tag: "Guide", desc: "Housing, healthcare, banking, and day-to-day life for new arrivals." },
          { title: "Saudi Salaries 2026", href: "/saudi-arabia/salaries/", tag: "Salary", desc: "Salary ranges for 20 professions from engineering to healthcare." },
          { title: "Relocating from UK", href: "/relocating-from/uk/", tag: "Relocation", desc: "Tax planning, international schools, and lifestyle comparison for British expats." },
          { title: "Qatar Labor Law", href: "/qatar/labor-law/", tag: "Law", desc: "Minimum wage, contract types, and worker protection regulations." },
        ].map((guide) => (
          <a href={guide.href} class="group bg-white dark:bg-gray-800 rounded-xl border border-gray-200 dark:border-gray-700 p-5 hover:border-teal-400 dark:hover:border-teal-600 hover:shadow-md transition-all">
            <span class="inline-block text-[10px] font-semibold uppercase tracking-wider text-teal-600 dark:text-teal-400 bg-teal-50 dark:bg-teal-900/30 px-2 py-0.5 rounded-md mb-3">{guide.tag}</span>
            <h3 class="font-semibold text-gray-900 dark:text-white text-sm group-hover:text-teal-600 dark:group-hover:text-teal-400 transition-colors">{guide.title}</h3>
            <p class="mt-1.5 text-xs text-gray-500 dark:text-gray-400 leading-relaxed">{guide.desc}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ Section -->
  <section class="py-16 bg-white dark:bg-gray-950">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <FAQAccordion faqs={faqs} />
    </div>
  </section>

  <!-- Trust / methodology section -->
  <section class="py-16 bg-gray-50 dark:bg-gray-900 border-t border-gray-200 dark:border-gray-800">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="lg:grid lg:grid-cols-12 lg:gap-12 items-start">
        <div class="lg:col-span-4">
          <div class="flex items-center gap-4">
            <img
              src={SITE.author.image}
              alt={SITE.author.name}
