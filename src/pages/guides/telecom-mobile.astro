      <a href="/qatar/telecom/" class="inline-flex items-center px-3 py-1.5 text-sm font-medium text-teal-600 dark:text-teal-400 bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg hover:border-teal-400 transition-colors">Qatar Telecom</a>
      <a href="/saudi-arabia/telecom/" class="inline-flex items-center px-3 py-1.5 text-sm font-medium text-teal-600 dark:text-teal-400 bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg hover:border-teal-400 transition-colors">Saudi Telecom</a>
    </div>
