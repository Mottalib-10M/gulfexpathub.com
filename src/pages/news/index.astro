---
import GuideLayout from "../../layouts/GuideLayout.astro";
import { buildBreadcrumbs, buildArticleSchema } from "../../lib/seo";
import { SITE } from "../../data/site-config";

const breadcrumbs = [
  { name: "Home", url: "https://gulfexpathub.com/" },
  { name: "News", url: "https://gulfexpathub.com/news/" },
];

const articles = [
  {
    title: "GCC Expat Policy Changes 2025: Golden Visas, Remote Work Permits & Residency Reforms",
    description: "A comprehensive look at the visa and residency changes reshaping expat life across the UAE, Qatar, and Saudi Arabia in 2025 -- from expanded golden visa categories to new remote work permits and long-term residency pathways.",
    href: "/news/gcc-expat-policy-changes-2025/",
    date: "2025-06-27",
    readingTime: "9 min",
  },
];

function formatDate(dateStr: string): string {
  return new Date(dateStr).toLocaleDateString("en-US", {
    year: "numeric",
    month: "long",
    day: "numeric",
  });
}
---

<GuideLayout
  title="GCC Expat News & Policy Updates"
  description="Latest news on visa changes, residency reforms, labor law updates, and policy developments affecting expats in the UAE, Qatar, and Saudi Arabia."
  canonical="/news/"
  schemas={[buildBreadcrumbs(breadcrumbs), buildArticleSchema("GCC Expat News & Policy Updates", "News and policy updates for Gulf expats.", "https://gulfexpathub.com/news/", "2025-06-27", "2025-06-27")]}
  breadcrumbs={[{ name: "Home", url: "/" }, { name: "News", url: "/news/" }]}
>
  <h1>GCC Expat News & Policy Updates</h1>

  <p>Stay informed on the latest visa changes, residency reforms, labor law updates, and policy developments affecting expatriates across the UAE, Qatar, and Saudi Arabia. Each article is researched using official government sources and updated as new regulations take effect.</p>

  <div class="not-prose grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5 my-8">
    {articles.map((article) => (
      <a
        href={article.href}
        class="group bg-gray-50 dark:bg-gray-900 rounded-2xl border border-gray-200 dark:border-gray-800 p-5 hover:border-teal-400 dark:hover:border-teal-500 hover:shadow-md transition-all"
      >
        <div class="flex items-center gap-2 text-xs text-gray-500 dark:text-gray-400 mb-3">
          <time datetime={article.date}>{formatDate(article.date)}</time>
          <span>&middot;</span>
          <span>{article.readingTime} read</span>
        </div>
        <h2 class="font-semibold text-gray-900 dark:text-white group-hover:text-teal-600 dark:group-hover:text-teal-400 transition-colors text-sm leading-snug">
          {article.title}
        </h2>
        <p class="mt-2 text-xs text-gray-500 dark:text-gray-400 leading-relaxed">
          {article.description}
        </p>
        <span class="inline-flex items-center gap-1 mt-3 text-xs font-semibold text-teal-600 dark:text-teal-400">
          Read article
          <svg class="w-3.5 h-3.5 group-hover:translate-x-0.5 transition-transform" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="9 18 15 12 9 6" />
          </svg>
        </span>
      </a>
    ))}
  </div>
</GuideLayout>
