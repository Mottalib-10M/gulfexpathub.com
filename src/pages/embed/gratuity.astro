---
import "../../styles/global.css";
import GratuityCalculator from "../../components/calculators/GratuityCalculator";
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Gratuity Calculator Widget - Gulf Expat Hub</title>
    <meta name="robots" content="noindex, nofollow" />
    <link rel="preload" href="/fonts/inter-var.woff2" as="font" type="font/woff2" crossorigin />
    <script is:inline>
      (function() {
        const stored = localStorage.getItem("theme");
        if (stored === "dark" || (!stored && window.matchMedia("(prefers-color-scheme: dark)").matches)) {
          document.documentElement.classList.add("dark");
        }
      })();
    </script>
    <style>
      body { margin: 0; padding: 16px; background: transparent; }
    </style>
  </head>
  <body class="bg-white dark:bg-gray-950 text-gray-900 dark:text-gray-100 antialiased">
    <div class="max-w-2xl mx-auto">
      <GratuityCalculator client:idle country="uae" currency="AED" countryName="UAE" />
      <p class="text-center text-xs text-gray-400 dark:text-gray-500 mt-4">
        Powered by <a href="https://gulfexpathub.com/calculators/" target="_blank" rel="noopener noreferrer" class="underline hover:text-teal-600">Gulf Expat Hub</a>
      </p>
    </div>
  </body>
</html>
